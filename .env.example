# Copie para .env e ajuste se quiser.  cp .env.example .env

# --- MinIO / credenciais S3 (usadas também pelo Trino para ler/escrever) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Estas DEVEM bater com o que está em infra/trino/catalog/*.properties
# (s3.aws-access-key / s3.aws-secret-key). Trino é o cliente Iceberg que
# fala direto com o S3; o Nessie só guarda os ponteiros de metadados.
